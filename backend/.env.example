# =============================================
# ARITTH MARKET (AMT) - BACKEND ENVIRONMENT
# =============================================

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
APP_NAME="Aritth Market"
APP_PREFIX=AMT
FRONTEND_URL=http://localhost:3000

# =============================================
# DATABASE (PostgreSQL 16 + pgvector)
# =============================================
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/aritth_market"

# =============================================
# REDIS (para BullMQ job queues)
# =============================================
REDIS_URL="redis://localhost:6379"

# =============================================
# CLERK AUTHENTICATION
# =============================================
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY_HERE

# =============================================
# GOOGLE / GEMINI AI (para búsqueda semántica)
# Obtener en: https://makersuite.google.com/app/apikey
# =============================================
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# =============================================
# EMAIL - Gmail SMTP (ventas@aritth.com)
# App Password: Gmail > Seguridad > Contraseñas de aplicación
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ventas@aritth.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD_HERE
SMTP_FROM="Aritth Market <ventas@aritth.com>"
INTERNAL_EMAIL=ventas@aritth.com

# =============================================
# TIPOS DE CAMBIO - ExchangeRate-API
# Registrarse gratis: https://www.exchangerate-api.com
# Plan gratuito: 1,500 requests/mes
# =============================================
EXCHANGE_RATE_API_KEY=YOUR_EXCHANGERATE_API_KEY_HERE
FALLBACK_USD_RATE=510
FALLBACK_EUR_RATE=560

# =============================================
# ALMACENAMIENTO LOCAL DE PDFs
# =============================================
STORAGE_PATH=./storage
STORAGE_MODE=local

# =============================================
# SCRAPING CONFIG
# =============================================
SCRAPING_DELAY_MS=1200
MAX_PAGES_PER_CATEGORY=10
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# =============================================
# PRICING
# =============================================
DEFAULT_MARGIN=0.10
IVA_RATE=0.13

# =============================================
# GOOGLE CLOUD (OAuth para Clerk)
# =============================================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
